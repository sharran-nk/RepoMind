# ============================================================
# RepoMind - .gitignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ------------------------------------------------------------
# Virtual Environment
# ------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ------------------------------------------------------------
# Environment Variables
# ------------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Streamlit
# ------------------------------------------------------------
.streamlit/secrets.toml

# ------------------------------------------------------------
# Repository Cache (Generated)
# ------------------------------------------------------------
cache/
temp_repos/

# ------------------------------------------------------------
# FAISS Indexes
# ------------------------------------------------------------
*.faiss
*.index

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# IDE
# ------------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Python Testing
# ------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Build Artifacts
# ------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# ------------------------------------------------------------
# Experimental / Local Development
# ------------------------------------------------------------
scratch/
RepoMind-caching-update/

# ------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo

# ------------------------------------------------------------
# Generated Archives
# ------------------------------------------------------------
*.zip
*.tar
*.gz
*.rar
*.7z

# ------------------------------------------------------------
# Local Database Files
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# ------------------------------------------------------------
# Keep these folders tracked even if empty
# ------------------------------------------------------------
!assets/
!.streamlit/